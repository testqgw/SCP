{
  "name": "nba-player-prop-snapshot",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "refresh:full": "tsx --env-file=.env.local --env-file=.env scripts/run-refresh.ts full",
    "refresh:delta": "tsx --env-file=.env.local --env-file=.env scripts/run-refresh.ts delta",
    "season:backfill": "tsx --env-file=.env.local --env-file=.env scripts/backfill-season-stats.ts",
    "season:last3": "tsx --env-file=.env.local --env-file=.env scripts/backfill-last3-seasons-nbastats.ts",
    "season:scrape3": "tsx --env-file=.env.local --env-file=.env scripts/backfill-three-season-scrape.ts",
    "season:export": "tsx --env-file=.env.local --env-file=.env scripts/export-season-stats.ts",
    "lines:export": "tsx --env-file=.env.local --env-file=.env scripts/export-historical-prop-lines.ts",
    "lines:export:player-page": "tsx --env-file=.env.local --env-file=.env scripts/export-historical-player-page-lines.ts",
    "lines:export:all": "tsx --env-file=.env.local --env-file=.env scripts/export-historical-pts-lines-all.ts",
    "lines:export:all-pts": "tsx --env-file=.env.local --env-file=.env scripts/export-historical-pts-lines-all.ts --market PTS",
    "projection:backtest": "tsx --env-file=.env.local --env-file=.env scripts/backtest-projection-model.ts",
    "projection:backtest:player": "tsx --env-file=.env.local --env-file=.env scripts/backtest-player-season.ts",
    "projection:analyze:player-pts": "tsx --env-file=.env.local --env-file=.env scripts/analyze-player-pts-report.ts",
    "projection:report:player-model": "tsx --env-file=.env.local --env-file=.env scripts/build-player-final-model-report.ts",
    "projection:backtest:tuned": "tsx --env-file=.env.local --env-file=.env scripts/backtest-projection-model.ts --opponent-window 20 --player-bias-weight 0.15 --player-bias-window 24 --global-bias-weight 1 --global-bias-min-samples 10",
    "projection:backtest:best": "tsx --env-file=.env.local --env-file=.env scripts/backtest-projection-model.ts --season 2025 --from 2025-10-01 --to 2026-03-02 --mode model --player-bias-weight 0.12 --player-bias-window 30 --global-bias-weight 1.3 --global-bias-min-samples 1 --rest-weight 0.08 --rest-min-samples 6 --quantile-clamp-weight 0.08 --quantile-clamp-min-samples 16 --median-blend-weight 0.12 --median-blend-take 36 --composite-from-core --out exports/projection-backtest-teamaware-best-compositecore-2025-to-2026-03-02.json",
    "projection:backtest:pts-best": "tsx --env-file=.env.local --env-file=.env scripts/backtest-projection-model.ts --season 2025 --from 2025-10-01 --to 2026-03-02 --mode model --player-bias-weight 0.15 --player-bias-window 32 --global-bias-weight 1.3 --global-bias-min-samples 1 --rest-weight 0.08 --rest-min-samples 6 --quantile-clamp-weight 0.08 --quantile-clamp-min-samples 16 --median-blend-weight 0.15 --median-blend-take 38 --pts-trend-reversion-weight -0.04 --pts-trend-reversion-cap 1.6 --pts-global-linear-weight 0.9 --pts-global-linear-window 1800 --out exports/projection-backtest-pts-best-2025-to-2026-03-02.json",
    "projection:train:player-models": "tsx --env-file=.env.local --env-file=.env scripts/train-player-market-side-models.ts",
    "projection:train:universal-models": "tsx --env-file=.env.local --env-file=.env scripts/train-universal-archetype-side-models.ts",
    "projection:build:universal-hybrid": "tsx --env-file=.env.local --env-file=.env scripts/build-universal-hybrid-model.ts",
    "projection:build:universal-calibration": "tsx --env-file=.env.local --env-file=.env scripts/build-universal-residual-calibration.ts",
    "projection:build:universal-projection-distribution": "tsx --env-file=.env.local --env-file=.env scripts/build-universal-projection-distribution.ts",
    "projection:lines:export:all-markets": "tsx --env-file=.env.local --env-file=.env scripts/export-historical-all-player-lines.ts",
    "projection:evaluate:universal-qualification": "tsx --env-file=.env.local --env-file=.env scripts/evaluate-universal-model-qualification.ts",
    "projection:evaluate:precision-picks": "tsx --env-file=.env.local --env-file=.env scripts/evaluate-precision-pick-system.ts",
    "projection:search:daily6": "tsx --env-file=.env.local --env-file=.env scripts/search-daily6-one-pick-per-player.ts",
    "projection:walk-forward:daily6": "tsx --env-file=.env.local --env-file=.env scripts/walk-forward-daily6.ts",
    "projection:retrain:universal-live": "tsx --env-file=.env.local --env-file=.env scripts/retrain-live-universal-model.ts",
    "monitor-weak-buckets": "tsx --env-file=.env.local --env-file=.env scripts/monitor-weak-buckets.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.554.0",
    "next": "14.2.13",
    "puppeteer": "^24.37.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@prisma/engines": "^6.19.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^20.12.14",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.13",
    "postcss": "^8.4.47",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.1.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.6.2"
  }
}
