# Core runtime
NODE_ENV="development"
DATABASE_URL="postgresql://username:password@localhost:5432/nba_snapshot?schema=public"

# Refresh access
# Manual refresh is opt-in for deployments that want a public refresh surface.
SNAPSHOT_ALLOW_MANUAL_REFRESH="false"
# Internal full/delta refresh routes stay CRON_SECRET-gated.
CRON_SECRET="replace-with-vercel-cron-secret"

# SportsDataIO
SPORTS_DATA_IO_API_KEY="replace-with-sportsdataio-key"
SPORTS_DATA_IO_BASE_URL="https://api.sportsdata.io/v3/nba"
SPORTS_DATA_IO_SCHEDULE_PATHS="/scores/json/GamesByDate/{date}"
SPORTS_DATA_IO_ACTIVE_SPORTSBOOKS_PATH="/odds/json/ActiveSportsbooks"
SPORTS_DATA_IO_BETTING_METADATA_PATH="/odds/json/BettingMetadata"
SPORTS_DATA_IO_BETTING_EVENTS_PATH="/odds/json/BettingEventsByDate/{date}"
SPORTS_DATA_IO_BETTING_PLAYER_PROPS_PATH="/odds/json/BettingPlayerPropsByGameID/{gameId}"
SPORTS_DATA_IO_PLAYER_PROPS_PATHS="/odds/json/PlayerPropsByDate/{date}"
SPORTS_DATA_IO_BOX_SCORES_FINAL_PATH="/stats/json/BoxScoresFinal/{date}"
SPORTS_DATA_IO_SEASON_STATS_PATHS="/stats/json/PlayerSeasonStats/{season}"
SPORTS_DATA_IO_INJURY_PATHS="/projections/json/InjuredPlayers"

# Quality gate
SNAPSHOT_QUALITY_GATE_ENABLED="true"
SNAPSHOT_ALLOW_LEGACY_PUBLISH="true"
