generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RefreshType {
  FULL
  DELTA
  CLEANUP
}

enum RefreshStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

model Team {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  abbreviation String  @unique
  name        String
  city        String?
  conference  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  homeGames          Game[] @relation("HomeTeam")
  awayGames          Game[] @relation("AwayTeam")
  players            Player[]
  logsAsTeam         PlayerGameLog[] @relation("LogTeam")
  logsAsOpponent     PlayerGameLog[] @relation("LogOpponent")

  @@map("teams")
}

model Player {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  fullName    String
  firstName   String?
  lastName    String?
  position    String?
  usageRate   Float?
  isActive    Boolean  @default(true)
  teamId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team            Team?               @relation(fields: [teamId], references: [id], onDelete: SetNull)
  gameLogs        PlayerGameLog[]

  @@index([teamId])
  @@map("players")
}

model Game {
  id             String   @id @default(cuid())
  externalId     String   @unique
  gameDateEt     String
  season         String?
  status         String?
  commenceTimeUtc DateTime?
  homeTeamId     String
  awayTeamId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  homeTeam       Team                @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam       Team                @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)

  @@index([gameDateEt])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@map("games")
}

model PlayerGameLog {
  id             String   @id @default(cuid())
  playerId       String
  externalGameId String
  gameDateEt     String
  teamId         String?
  opponentTeamId String?
  minutes        Float?
  points         Float?
  rebounds       Float?
  assists        Float?
  threes         Float?
  steals         Float?
  blocks         Float?
  turnovers      Float?
  pace           Float?
  total          Float?
  isHome         Boolean?
  starter        Boolean?
  played         Boolean?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  player         Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team           Team?  @relation("LogTeam", fields: [teamId], references: [id], onDelete: SetNull)
  opponentTeam   Team?  @relation("LogOpponent", fields: [opponentTeamId], references: [id], onDelete: SetNull)

  @@index([gameDateEt])
  @@index([playerId, gameDateEt])
  @@index([opponentTeamId, gameDateEt])
  @@unique([playerId, externalGameId])
  @@map("player_game_logs")
}

model RefreshRun {
  id            String        @id @default(cuid())
  type          RefreshType
  status        RefreshStatus @default(RUNNING)
  startedAt     DateTime      @default(now())
  completedAt   DateTime?
  durationMs    Int?
  totalGames    Int           @default(0)
  totalPlayers  Int           @default(0)
  errorCount    Int           @default(0)
  warningCount  Int           @default(0)
  isPublishable Boolean       @default(false)
  qualityIssues Json?
  errorMessage  String?
  notes         Json?

  @@index([startedAt])
  @@map("refresh_runs")
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
