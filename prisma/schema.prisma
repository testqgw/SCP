generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Market {
  PTS
  REB
  AST
  THREES
  PRA
  PA
  PR
  RA
  STL
  BLK
  TOV
  DOUBLE_DOUBLE
  TRIPLE_DOUBLE
}

enum Side {
  OVER
  UNDER
}

enum Confidence {
  A
  B
  C
  LOW
}

enum RefreshType {
  FULL
  DELTA
  CLEANUP
}

enum RefreshStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

model Team {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  abbreviation String  @unique
  name        String
  city        String?
  conference  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  homeGames          Game[] @relation("HomeTeam")
  awayGames          Game[] @relation("AwayTeam")
  players            Player[]
  logsAsTeam         PlayerGameLog[] @relation("LogTeam")
  logsAsOpponent     PlayerGameLog[] @relation("LogOpponent")

  @@map("teams")
}

model Player {
  id          String   @id @default(cuid())
  externalId  String?  @unique
  fullName    String
  firstName   String?
  lastName    String?
  position    String?
  usageRate   Float?
  isActive    Boolean  @default(true)
  teamId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team            Team?               @relation(fields: [teamId], references: [id], onDelete: SetNull)
  gameLogs        PlayerGameLog[]
  propSnapshots   PropLineSnapshot[]
  metrics         PlayerMarketMetric[]
  edgeSnapshots   EdgeSnapshot[]

  @@index([teamId])
  @@map("players")
}

model Game {
  id             String   @id @default(cuid())
  externalId     String   @unique
  gameDateEt     String
  season         String?
  status         String?
  commenceTimeUtc DateTime?
  homeTeamId     String
  awayTeamId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  homeTeam       Team                @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam       Team                @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)
  propSnapshots  PropLineSnapshot[]
  metrics        PlayerMarketMetric[]
  edgeSnapshots  EdgeSnapshot[]

  @@index([gameDateEt])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@map("games")
}

model PlayerGameLog {
  id             String   @id @default(cuid())
  playerId       String
  externalGameId String
  gameDateEt     String
  teamId         String?
  opponentTeamId String?
  minutes        Float?
  points         Float?
  rebounds       Float?
  assists        Float?
  threes         Float?
  steals         Float?
  blocks         Float?
  turnovers      Float?
  pace           Float?
  total          Float?
  isHome         Boolean?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  player         Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team           Team?  @relation("LogTeam", fields: [teamId], references: [id], onDelete: SetNull)
  opponentTeam   Team?  @relation("LogOpponent", fields: [opponentTeamId], references: [id], onDelete: SetNull)

  @@index([gameDateEt])
  @@index([playerId, gameDateEt])
  @@index([opponentTeamId, gameDateEt])
  @@unique([playerId, externalGameId])
  @@map("player_game_logs")
}

model Sportsbook {
  id                  String   @id @default(cuid())
  code                String   @unique
  displayName         String
  providerSportsbookId Int?    @unique
  providerNameRaw     String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  propSnapshots PropLineSnapshot[]
  metrics       PlayerMarketMetric[]
  edgeSnapshots EdgeSnapshot[]

  @@map("sportsbooks")
}

model PropLineSnapshot {
  id                  String   @id @default(cuid())
  gameId              String
  playerId            String
  sportsbookId        String
  market              Market
  rawMarketName       String
  line                Float
  overPrice           Int?
  underPrice          Int?
  providerMarketId    String?
  providerBetTypeId   Int?
  providerPeriodTypeId Int?
  providerOutcomeType String?
  teamCodeProvider    String?
  opponentCodeProvider String?
  teamCodeCanonical   String?
  opponentCodeCanonical String?
  sourceFeed          String?
  capturedAt          DateTime
  createdAt           DateTime @default(now())

  game          Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player        Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  sportsbook    Sportsbook @relation(fields: [sportsbookId], references: [id], onDelete: Cascade)

  @@index([gameId, sportsbookId, market])
  @@index([playerId, market])
  @@index([capturedAt])
  @@map("prop_line_snapshots")
}

model PlayerMarketMetric {
  id                    String   @id @default(cuid())
  refreshRunId          String
  playerId              String
  gameId                String
  sportsbookId          String
  market                Market
  line                  Float
  last5OverRate         Float
  last5UnderRate        Float
  seasonOverRate        Float
  seasonUnderRate       Float
  bounceBackFlag        Boolean
  bounceBackScore       Float
  archetypeKey          String
  opponentAllowanceDelta Float
  lineValueScore        Float
  minutesTrendScore     Float
  paceTotalScore        Float
  injuryContextScore    Float
  recentFormScore       Float
  seasonVsLineScore     Float
  updatedAt             DateTime @default(now())

  refreshRun            RefreshRun @relation(fields: [refreshRunId], references: [id], onDelete: Cascade)
  player                Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game                  Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  sportsbook            Sportsbook @relation(fields: [sportsbookId], references: [id], onDelete: Cascade)

  @@unique([refreshRunId, playerId, gameId, sportsbookId, market])
  @@index([playerId, market])
  @@index([sportsbookId, market, gameId])
  @@map("player_market_metrics")
}

model EdgeSnapshot {
  id                    String   @id @default(cuid())
  refreshRunId          String
  playerId              String
  gameId                String
  sportsbookId          String
  market                Market
  line                  Float
  overPrice             Int?
  underPrice            Int?
  recommendedSide       Side
  overEdgeScore         Float
  underEdgeScore        Float
  edgeScore             Float
  confidence            Confidence
  last5OverRate         Float
  bounceBackFlag        Boolean
  opponentAllowanceDelta Float
  archetypeKey          String
  lineMove24h           Float
  dataSource            String?
  componentScores       Json
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  refreshRun            RefreshRun @relation(fields: [refreshRunId], references: [id], onDelete: Cascade)
  player                Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game                  Game       @relation(fields: [gameId], references: [id], onDelete: Cascade)
  sportsbook            Sportsbook @relation(fields: [sportsbookId], references: [id], onDelete: Cascade)

  @@unique([refreshRunId, playerId, gameId, sportsbookId, market])
  @@index([playerId, market])
  @@index([sportsbookId, market, gameId])
  @@map("edge_snapshots")
}

model RefreshRun {
  id            String        @id @default(cuid())
  type          RefreshType
  status        RefreshStatus @default(RUNNING)
  startedAt     DateTime      @default(now())
  completedAt   DateTime?
  durationMs    Int?
  totalGames    Int           @default(0)
  totalPlayers  Int           @default(0)
  totalLines    Int           @default(0)
  totalEdges    Int           @default(0)
  errorCount    Int           @default(0)
  warningCount  Int           @default(0)
  isPublishable Boolean       @default(false)
  qualityIssues Json?
  errorMessage  String?
  notes         Json?

  metrics       PlayerMarketMetric[]
  edgeSnapshots EdgeSnapshot[]

  @@index([startedAt])
  @@map("refresh_runs")
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
